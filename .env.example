# Copy to `.env` / `.env.local` and fill in (never commit real secrets).

# Prisma → Supabase Postgres (from Dashboard → Connect → URI)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Supabase client (App Router) — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your_anon_or_publishable_key"
